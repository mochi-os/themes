// Mochi Themes app
// Provides themes for the Mochi platform

{
	"version": "1.14",
	"label": "app.name",
	"paths": ["themes"],

	"architecture": {"engine": "starlark", "version": 4},
	"execute": [],

	// The five curated themes (blue, rose, terracotta, teal, steel)
	// are colour swatches, standardised on spacing (comfortable),
	// border_radius (0.375rem) and the -5 hue_bg offset, with backgrounds on.
	// Each theme's primary is a deliberately balanced (hue, chroma,
	// lightness): hue carries the identity, while chroma and the --primary-l
	// lightness override (in overrides) are tuned per hue. Most sit at the
	// same perceived saturation (C/L ~0.277, anchored to blue) — a fixed
	// chroma instead clamps blue (sRGB ceiling 0.135 at its hue/L) and
	// over-saturates the others. Two exceptions: teal is gamut-capped
	// (cyan's sRGB chroma ceiling is ~0.09, so it can't reach 0.277 and
	// reads as a muted teal), and steel is deliberately desaturated (C 0.055)
	// to read as a calm slate-blue rather than a punchy primary. At the
	// default L 0.488 a warm hue renders as a dark brown and teal is a dull
	// dark cyan, so terracotta (0.55), teal (0.52) and steel (0.50) lift
	// lightness. Density, radius,
	// font, font size, and background visibility are each their own user
	// preference, so users mix and match orthogonally.
	//
	// Theme manifest fields (see AppTheme in core/server/apps.go):
	//   id            — unique identifier (used in user preferences)
	//   label         — i18n key resolved from labels/<lang>.conf
	//   hue           — primary color hue in OKLCH color space (0–360)
	//   chroma        — color saturation (0 = grey, ~0.2 = vivid)
	//   hue_bg        — background/secondary hue (can differ from primary)
	//   spacing       — default layout density: "compact" | "comfortable" | "spacious"
	//   border_radius — default corner rounding: "0rem" | "0.375rem" | "0.75rem" | "1.75rem"
	//   background    — optional SVG filename in backgrounds/ (light)
	//   background_dark — optional SVG filename in backgrounds/ (dark)
	//
	// Other fields the schema supports but the bundled themes don't set:
	//   font_sans / font_mono — for "design-pack" themes that bundle
	//     typography with colour. Bundled themes inherit the platform
	//     default (system UI sans / IBM Plex Mono), so font stays an
	//     orthogonal user preference.
	//   icon_mask / icon_background / icons — substrate for future
	//     theme icon packs (Brutalist, Material, …). Resolution code is
	//     in api_app_icons; no theme exercises these yet.
	//   overrides — map of raw CSS custom properties injected on <html>,
	//     overriding theme.css. Used for --primary-l (per-theme primary
	//     lightness; terracotta/teal/steel) and --card-shadow / --card-border-width
	//     (per-theme card surface treatment — no bundled theme currently sets
	//     these, so all default to border+shadow; users pick Flat/Raised via the
	//     "card" preference). The picker honours --primary-l for the swatch.
	"themes": [
		{
			"id": "blue",
			"label": "theme_blue",
			"hue": 250,
			"chroma": 0.135,
			"hue_bg": 245,
			"spacing": "comfortable",
			"border_radius": "0.375rem",
			"background": "blue.svg",
			"background_dark": "blue-dark.svg"
		},
		{
			"id": "rose",
			"label": "theme_rose",
			"hue": 350,
			"chroma": 0.135,
			"hue_bg": 345,
			"spacing": "comfortable",
			"border_radius": "0.375rem",
			"background": "rose.svg",
			"background_dark": "rose-dark.svg"
		},
		{
			"id": "terracotta",
			"label": "theme_terracotta",
			"hue": 40,
			"chroma": 0.15,
			"hue_bg": 35,
			"spacing": "comfortable",
			"border_radius": "0.375rem",
			"background": "terracotta.svg",
			"background_dark": "terracotta-dark.svg",
			"overrides": {"--primary-l": "0.55"}
		},
		{
			"id": "teal",
			"label": "theme_teal",
			"hue": 185,
			"chroma": 0.09,
			"hue_bg": 180,
			"spacing": "comfortable",
			"border_radius": "0.375rem",
			"background": "teal.svg",
			"background_dark": "teal-dark.svg",
			"overrides": {"--primary-l": "0.52"}
		},
		{
			"id": "steel",
			"label": "theme_steel",
			"hue": 250,
			"chroma": 0.055,
			"hue_bg": 245,
			"spacing": "comfortable",
			"border_radius": "0.375rem",
			"background": "steel.svg",
			"background_dark": "steel-dark.svg",
			"overrides": {"--primary-l": "0.50"}
		}
	],

	"actions": {
		"backgrounds": {"files": "backgrounds", "cache": "static", "public": true}
	}
}
